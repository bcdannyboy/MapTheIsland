{
  "name": "@maptheisland/web",
  "private": true,
  "version": "0.0.0-phase-00",
  "description": "Phase 00 frontend baseline for the MapTheIsland evidence workbench.",
  "type": "module",
  "engines": {
    "node": ">=20.9.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test:unit": "vitest run --coverage",
    "test:e2e": "playwright test --pass-with-no-tests",
    "test:e2e:headed": "playwright test --pass-with-no-tests --headed",
    "test:e2e:ui": "playwright test --pass-with-no-tests --ui"
  },
  "dependencies": {
    "next": "^16.1.6",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/node": "^24.3.1",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.5",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "vitest": {
    "coverage": {
      "provider": "v8",
      "include": [
        "playwright.config.ts"
      ],
      "exclude": [
        "tests/**"
      ],
      "reporter": [
        "text"
      ],
      "thresholds": {
        "lines": 100,
        "functions": 100,
        "branches": 100,
        "statements": 100
      }
    }
  }
}
